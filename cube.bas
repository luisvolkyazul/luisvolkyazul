10 MODE 24
20 GCOL 0,2
25 FOR X = 0 TO 1000
30 F% = OPENIN "CUBE.SEQ"
40 REPEAT
50   T% = VAL(GET$#F% TO 44)
60   X% = VAL(GET$#F% TO 44)
70   Y% = VAL(GET$#F%)
80   IF T% = 1 DRAW X%, Y% ELSE MOVE X%, Y%
85 GCOL 0, RND(16): REM CHANGE COLORS RANDOMLY
90 UNTIL T% = 3 OR EOF#F%
100 CLOSE#F%
105 FOR Y = 0 TO 100: NEXT Y
110 NEXT X
