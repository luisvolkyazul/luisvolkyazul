    1 REM ADAPTED TO RUN ON THE AGON LIGHT 2 MICROCOMPUTER
    5 REM FROM RTRUSSELL
   10 MODE 0
   12 GCOL 0,2
   15 REM VW.SEQ FROM GEORGE'S CHANNEL ON YOUTUBE
   20 F% = OPENIN "VW.SEQ"
   30 REPEAT
   40   T% = VAL(GET$#F% TO 44)
   50   X% = 3 * VAL(GET$#F% TO 44)
   60   Y% = 3 * VAL(GET$#F%)
   70   IF T% = 1 DRAW X%, 960-Y% ELSE MOVE X%, 960-Y%
   71   REM FOR I = 0 TO 500: NEXT I
   75   REM GCOL 0,RND(15)
   80 UNTIL T% = 3 OR EOF#F%
   90 CLOSE#F%
