   10 MODE 8: REM 16-COLOR
   20 LET X=640: LET Y=512: LET DX=3: LET DY=2:LET SIZE=80
   30 CLS
   50 REPEAT
   60   GCOL 0, RND(16)-1 : REM SET RANDOM COLOR 0-15
   70   RECTANGLE FILL X-SIZE/2, Y-SIZE/2, SIZE, SIZE
   80   X = X + DX: Y = Y + DY
   90   IF X - SIZE/2 < 0 OR X + SIZE/2 > 640*2 THEN LET DX = -DX
  100   IF Y - SIZE/2 < 0 OR Y + SIZE/2 > 512*2 THEN LET DY = -DY
  110   FOR D = 1 TO 100: NEXT
  120 UNTIL FALSE
